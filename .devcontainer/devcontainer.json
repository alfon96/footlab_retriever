{
  "name": "FootlabRetriever",
  "dockerComposeFile": "../../docker-compose.yml",
  "service": "retriever",
  "workspaceFolder": "/retriever",
   "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.black-formatter"],
      "settings": {
        "python.defaultInterpreterPath": "/venv/bin/python"
      }
    }
  },
  
"postCreateCommand": "git config --global --add safe.directory /retriever"
}
